import { describe, it, before, after } from "node:test";
import { strict as assert } from "node:assert";
import { writeFileSync, mkdirSync, rmSync, readFileSync } from "fs";
import { join } from "path";
import { spawn } from "child_process";

const REPO = "/tmp/mcp-code-shrinker";

function jsonRpc(method, params, id) {
  return JSON.stringify({ jsonrpc: "2.0", id, method, params }) + "\n";
}

function rpcCall(server, method, params) {
  const id = Math.random().toString(36).slice(2);
  server.stdin.write(jsonRpc(method, params, id));
  return new Promise((res, rej) => {
    const t = setTimeout(() => rej(new Error("RPC timeout: " + method)), 10000);
    let buf = "";
    const onData = (d) => {
      buf += d.toString();
      for (const line of buf.split("\n").filter(l => l.trim())) {
        try {
          const r = JSON.parse(line);
          if (r.id === id) { clearTimeout(t); server.stdout.removeListener("data", onData); res(r); }
        } catch {}
      }
    };
    server.stdout.on("data", onData);
  });
}

describe("E2E workflow", () => {
  const tmp = "/tmp/e2e-" + Date.now();
  const srcFile = join(tmp, "src", "calc.js");
  let server;

  before(async () => {
    mkdirSync(join(tmp, "src"), { recursive: true });
    writeFileSync(srcFile, "export function add(a, b) {\n  return a + b;\n}\n");

    server = spawn(process.execPath, [join(REPO, "src", "index.js")], {
      cwd: REPO,
      env: { ...process.env, CODE_SHRINKER_ALLOWED_ROOTS: tmp },
      stdio: ["pipe", "pipe", "pipe"],
    });

    let stderr = "";
    await new Promise((res, rej) => {
      const t = setTimeout(() => rej(new Error("startup timeout")), 8000);
      server.stderr.on("data", d => { stderr += d.toString(); if (stderr.includes("ready")) { clearTimeout(t); res(); } });
      server.on("error", rej);
    });
  });

  after(() => { server?.kill(); try { rmSync(tmp, { recursive: true }); } catch {} });

  it("propose → validate → apply cycle", async () => {
    // Initialize
    await rpcCall(server, "initialize", { protocolVersion: "1.0", capabilities: {}, clientInfo: { name: "e2e", version: "1" } });
    await rpcCall(server, "notifications/initialized", {});

    // Context create (must not crash on rootForFile(tf))
    const ctx = await rpcCall(server, "tools/call", {
      name: "context.create",
      arguments: { task: { type: "bugfix", description: "fix", target: "add" }, targetFile: srcFile, mode: "safe" }
    });
    assert.ok(ctx.result, "context.create must succeed: " + JSON.stringify(ctx).slice(0, 150));
    const cdata = JSON.parse(ctx.result.content?.[0]?.text || "{}");
    const ctxId = cdata.contextId;
    assert.ok(ctxId, "contextId required: " + JSON.stringify(cdata).slice(0, 100));

    // Propose
    const prop = await rpcCall(server, "tools/call", {
      name: "patch.propose",
      arguments: { contextId: ctxId, edits: [{ operation: "replace_symbol", symbol: "@add", code: "export function add(a, b) {\n  return a + b + 0;\n}\n" }] }
    });
    const pdata = JSON.parse(prop.result.content?.[0]?.text || "{}");
    assert.ok(pdata.patchId, "patchId required: " + JSON.stringify(pdata).slice(0, 100));

    // Validate
    const val = await rpcCall(server, "tools/call", { name: "patch.validate", arguments: { patchId: pdata.patchId } });
    const vdata = JSON.parse(val.result.content?.[0]?.text || "{}");
    assert.ok(vdata.status === "valid" || vdata.status === "inconclusive", "status: " + vdata.status);

    // Apply
    const app = await rpcCall(server, "tools/call", { name: "patch.apply", arguments: { patchId: pdata.patchId } });
    const adata = JSON.parse(app.result.content?.[0]?.text || "{}");
    assert.equal(adata.status, "applied", "apply: " + JSON.stringify(adata).slice(0, 200));
  });
});
